<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<!--
  Popup di conferma "Elimina brano".
-->
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.gruppo19.progetto_music_player.controller.DeleteTrackDialogController"
      styleClass="dialog-card" prefWidth="320.0" spacing="16.0" alignment="CENTER"
      stylesheets="@styles.css">
    <padding>
        <Insets top="28.0" right="24.0" bottom="20.0" left="24.0"/>
    </padding>

    <StackPane styleClass="badge, badge-danger">
        <!-- cestino -->
        <SVGPath styleClass="badge-glyph"
                 content="M3 6h18M8 6V4h8v2M6 6l1 14h10l1-14M10 11v6M14 11v6"/>
    </StackPane>

    <Label fx:id="mainLabel" styleClass="dialog-title"/>

    <Label fx:id="messageLabel" styleClass="dialog-text" wrapText="true"/>

    <HBox styleClass="dialog-footer">
        <padding><Insets top="4.0"/></padding>
        <Button text="No" styleClass="btn-secondary" onAction="#onCancel"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button text="Sì, elimina" styleClass="btn-danger" onAction="#onConfirm"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>
</VBox>
