<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>

<!--
  Music Player - Unica View presente
-->
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Slider?>
<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.gruppo19.progetto_music_player.controller.MainViewController"
      styleClass="app-root" prefWidth="1280.0" prefHeight="800.0"
      stylesheets="@styles.css">

    <!-- ============================ LEFT PANE ============================ -->
    <StackPane minWidth="380.0" prefWidth="380.0" maxWidth="380.0">
        <VBox styleClass="sidebar">

            <!-- Header: logo + segmented control (condiviso tra le due viste) -->
            <VBox styleClass="sidebar-header" spacing="24.0">
                <padding>
                    <Insets top="28.0" right="24.0" bottom="0.0" left="24.0"/>
                </padding>

                <TextFlow styleClass="logo">
                    <Text styleClass="logo-melo" text="Music Player Gruppo 19"/>
                </TextFlow>

                <HBox styleClass="segment" fx:id="tabSegment">
                    <fx:define>
                        <ToggleGroup fx:id="tabGroup"/>
                    </fx:define>
                    <ToggleButton fx:id="tabBrani" text="Brani" selected="true"
                                  toggleGroup="$tabGroup" styleClass="segment-btn"
                                  onAction="#onTabChanged"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <ToggleButton fx:id="tabPlaylist" text="Playlist"
                                  toggleGroup="$tabGroup" styleClass="segment-btn"
                                  onAction="#onTabChanged"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Section label (cambia in base alla tab) -->
            <Label fx:id="sectionLabel" text="LIBRERIA" styleClass="section-label">
                <padding>
                    <Insets top="20.0" right="24.0" bottom="8.0" left="24.0"/>
                </padding>
            </Label>

            <!-- Area lista: contiene sovrapposte la sidebar Brani e la sidebar Playlist.
                 Il controller mostra/nasconde quella attiva. -->
            <StackPane fx:id="libraryArea" VBox.vgrow="ALWAYS">

                <!-- - SIDEBAR BRANI- -->
                <StackPane fx:id="braniSidebar">
                    <ListView fx:id="songListView" styleClass="song-list"
                              visible="false" managed="false">

                        <padding>
                            <Insets top="16.0" right="12.0" bottom="16.0" left="12.0"/>

                        </padding>
                    </ListView>

                    <!-- EMPTY STATE - Nessun brano -->
                    <VBox fx:id="emptyLibrary" styleClass="empty-state">
                        <StackPane styleClass="empty-icon, empty-icon-music">
                            <Label text="♫" styleClass="empty-icon-glyph"/>
                        </StackPane>
                        <Label text="Nessun brano" styleClass="empty-title"/>
                        <Label styleClass="empty-text" wrapText="true"
                               text="La tua libreria è vuota. Aggiungi il tuo primo brano per cominciare."/>
                        <Button styleClass="btn-primary" onAction="#onAdd" text="+  Aggiungi brano"/>
                    </VBox>
                </StackPane>

                <!-- - SIDEBAR PLAYLIST -
                     Le righe playlist sono costruite dinamicamente dal
                     MainViewController: ogni box, al click, si espande in-line
                     mostrando tutti i brani della playlist (vedi refreshPlaylists). -->
                <ScrollPane fx:id="playlistSidebar" fitToWidth="true" styleClass="list-scroll"
                            visible="false" managed="false">
                    <ListView fx:id="playlistSidebarList" styleClass="song-list">
                        <padding><Insets top="16.0" right="12.0" bottom="16.0" left="12.0"/></padding>
                    </ListView>
                </ScrollPane>
            </StackPane>
        </VBox>

        <!-- Floating "add" button -->
        <Button fx:id="addButton" styleClass="fab" onAction="#onAdd"
                StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin>
                <Insets bottom="24.0" right="25.0"/>
            </StackPane.margin>
            <graphic>
                <SVGPath styleClass="fab-icon" content="M10 4.167v11.666M4.167 10h11.666"/>
            </graphic>
        </Button>
    </StackPane>

    <!-- ============================ RIGHT PANE ============================ -->
    <StackPane styleClass="content-area" HBox.hgrow="ALWAYS">

        <!-- CONTENUTO BRANI (player)- -->
        <VBox fx:id="playerCardEmpty" styleClass="player-card" maxWidth="440.0" maxHeight="713.0"
              spacing="16.0" alignment="CENTER">
            <padding>
                <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
            </padding>

            <StackPane styleClass="empty-icon, empty-icon-play">
                <SVGPath styleClass="play-icon-faint" content="M7 5v14l11-7z"/>
            </StackPane>
            <Label text="Nessun brano selezionato" styleClass="empty-title"/>
            <Label styleClass="empty-text" wrapText="true"
                   text="Seleziona un brano dalla libreria per iniziare ad ascoltare."/>

            <Region styleClass="dialog-divider" maxWidth="268.0">
                <VBox.margin><Insets top="8.0" bottom="8.0"/></VBox.margin>
            </Region>

            <!-- controlli decorativi (disattivati) -->
            <HBox alignment="CENTER" spacing="12.0">
                <Region styleClass="ghost-dash"/>
                <StackPane styleClass="ghost-play">
                    <Label text="▶" styleClass="empty-icon-glyph"/>
                </StackPane>
                <Region styleClass="ghost-dash"/>
            </HBox>
        </VBox>
        <!-- CONTENUTO BRANI (player) - stato attivo -->
        <VBox fx:id="playerCardActive" styleClass="player-card" maxWidth="440.0" maxHeight="713.0"
              spacing="20.0" alignment="CENTER" visible="false" managed="false">
            <padding>
                <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
            </padding>

            <!-- Copertina del brano -->
            <StackPane styleClass="player-cover">
                <ImageView fx:id="playerImage" fitWidth="280.0" fitHeight="280.0"
                           preserveRatio="true" pickOnBounds="true"/>
            </StackPane>

            <!-- Titolo + Artista -->
            <VBox spacing="6.0" alignment="CENTER" maxWidth="360.0">
                <Label fx:id="playerTitle" styleClass="player-title" text="Titolo"
                       maxWidth="Infinity" alignment="CENTER"/>
                <Label fx:id="playerArtist" styleClass="player-artist" text="Artista"
                       maxWidth="Infinity" alignment="CENTER"/>
            </VBox>

            <!-- Barra di avanzamento + durata -->
            <VBox spacing="6.0" maxWidth="360.0">
                <Slider fx:id="playerSlider" styleClass="player-slider" min="0.0" max="100.0" value="0.0"/>
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="playerCurrentTime" styleClass="player-time" text="0:00"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="playerDurata" styleClass="player-time" text="--:--"/>
                </HBox>
            </VBox>

            <!-- Controlli di riproduzione -->
            <HBox alignment="CENTER" spacing="24.0">
                <Button fx:id="prevButton" styleClass="player-ctrl" text="⏮"/>
                <Button fx:id="playPauseButton" styleClass="player-ctrl, player-ctrl-main" text="▶" onMouseClicked="#onPlayPause"/>
                <Button fx:id="nextButton" styleClass="player-ctrl" text="⏭"/>
            </HBox>

        </VBox>

    </StackPane>
</HBox>
