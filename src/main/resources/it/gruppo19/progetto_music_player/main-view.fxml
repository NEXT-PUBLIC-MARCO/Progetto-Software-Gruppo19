<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<!--
  Melodia - 01 Homepage
  Generated from the Figma design (frame "Melodia - 01 Homepage", 1280x800).
  Left: library sidebar with the song list. Right: the now-playing card.
-->
<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.gruppo19.progetto_music_player.controller.MainController"
      styleClass="app-root" prefWidth="1280.0" prefHeight="800.0"
      stylesheets="@styles.css">

    <!-- ============================ SIDEBAR ============================ -->
    <StackPane minWidth="380.0" prefWidth="380.0" maxWidth="380.0">
        <VBox styleClass="sidebar">

            <!-- Header: logo + segmented control -->
            <VBox styleClass="sidebar-header" spacing="24.0">
                <padding>
                    <Insets top="28.0" right="24.0" bottom="0.0" left="24.0"/>
                </padding>

                <TextFlow styleClass="logo">
                    <Text styleClass="logo-melo" text="melo"/>
                    <Text styleClass="logo-dia" text="dia"/>
                </TextFlow>

                <HBox styleClass="segment" fx:id="tabSegment">
                    <fx:define>
                        <ToggleGroup fx:id="tabGroup"/>
                    </fx:define>
                    <ToggleButton fx:id="tabBrani" text="Brani" selected="true"
                                  toggleGroup="$tabGroup" styleClass="segment-btn"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <ToggleButton fx:id="tabPlaylist" text="Playlist"
                                  toggleGroup="$tabGroup" styleClass="segment-btn"
                                  maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Section label -->
            <Label text="LIBRERIA" styleClass="section-label">
                <padding>
                    <Insets top="20.0" right="24.0" bottom="8.0" left="24.0"/>
                </padding>
            </Label>

            <!-- Song list -->
            <ScrollPane fitToWidth="true" styleClass="list-scroll" VBox.vgrow="ALWAYS">
                <VBox fx:id="songList" styleClass="song-list" spacing="2.0">
                    <padding>
                        <Insets top="16.0" right="12.0" bottom="16.0" left="12.0"/>
                    </padding>

                    <!-- Selected / now-playing row MOCK DATA -->
                    <HBox styleClass="song-row, song-row-selected" alignment="CENTER_LEFT" spacing="12.0">
                        <Region styleClass="thumb"/>
                        <VBox styleClass="song-meta" HBox.hgrow="ALWAYS" spacing="1.0">
                            <Label text="Deriva Lenta" styleClass="song-title, song-title-active"/>
                            <Label text="Marco Vento" styleClass="song-artist"/>
                        </VBox>
                        <Region styleClass="now-dot"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- Floating "add" button -->
        <Button fx:id="addButton" styleClass="fab" onAction="#onAdd"
                StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin>
                <Insets bottom="24.0" right="25.0"/>
            </StackPane.margin>
            <graphic>
                <SVGPath styleClass="fab-icon"
                         content="M10 4.167v11.666M4.167 10h11.666"/>
            </graphic>
        </Button>
    </StackPane>

    <!-- ============================ NOW PLAYING ============================ -->
    <StackPane styleClass="content-area" HBox.hgrow="ALWAYS">

        <VBox fx:id="playerCard" styleClass="player-card" maxWidth="440.0" maxHeight="713.0"
              spacing="24.0" alignment="TOP_CENTER">
            <padding>
                <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
            </padding>

            <!-- Album art -->
            <Region styleClass="album-art" VBox.vgrow="ALWAYS" maxWidth="Infinity"/>

            <!-- Title + artist -->
            <VBox spacing="4.0" maxWidth="Infinity">
                <Label fx:id="nowTitle" text="Deriva Lenta" styleClass="player-title"/>
                <Label fx:id="nowArtist" text="Marco Vento" styleClass="player-artist"/>
            </VBox>

            <!-- Progress -->
            <VBox spacing="8.0" maxWidth="Infinity">
                <ProgressBar fx:id="progress" progress="0.37" styleClass="player-progress"
                             maxWidth="Infinity"/>
                <HBox>
                    <Label fx:id="elapsed" text="1:23" styleClass="time-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="total" text="3:44" styleClass="time-label"/>
                </HBox>
            </VBox>

            <!-- Playback controls -->
            <HBox styleClass="controls" alignment="CENTER" spacing="16.0" maxWidth="Infinity">
                <Button fx:id="shuffleButton" text="⇄" styleClass="control-btn" onAction="#onShuffle"/>
                <Button fx:id="prevButton" text="⏮" styleClass="control-btn" onAction="#onPrev"/>
                <Button fx:id="playButton" styleClass="play-btn" onAction="#onPlayPause">
                    <graphic>
                        <SVGPath fx:id="playIcon" styleClass="play-icon" content="M5 3.5v13l11-6.5z"/>
                    </graphic>
                </Button>
                <Button fx:id="nextButton" text="⏭" styleClass="control-btn" onAction="#onNext"/>
                <Button fx:id="repeatButton" text="⟳" styleClass="control-btn" onAction="#onRepeat"/>
            </HBox>

            <!-- Actions -->
            <HBox styleClass="actions" alignment="CENTER" spacing="16.0" maxWidth="Infinity">
                <Button fx:id="addToPlaylistButton" text="+  Aggiungi a playlist"
                        styleClass="action-btn" onAction="#onAddToPlaylist"/>
                <Button fx:id="deleteButton" text="Elimina"
                        styleClass="action-btn, action-btn-danger" onAction="#onDelete"/>
            </HBox>
        </VBox>
    </StackPane>
</HBox>
