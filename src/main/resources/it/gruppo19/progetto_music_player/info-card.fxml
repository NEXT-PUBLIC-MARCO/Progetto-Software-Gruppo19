<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns:fx="http://javafx.com/fxml"
      styleClass="track-card"
      maxWidth="Infinity"
      fillWidth="true">

    <!-- Riga principale -->
    <HBox prefHeight="80" minHeight="80" spacing="12" alignment="CENTER_LEFT" maxWidth="Infinity">

        <ImageView fx:id="cardImage" fitWidth="60" fitHeight="60"/>

        <VBox spacing="4" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <Label fx:id="titleLabel" styleClass="track-title" text="Titolo"/>
            <Label fx:id="subtitleLabel" styleClass="track-artist" text="Sottotitolo"/>
        </VBox>

        <ToggleButton fx:id="searchToggle" text="🔍" style="-fx-font-size: 12px;"/>
        <Button fx:id="menuButton" text="☰" style="-fx-font-size: 12px;"/>

    </HBox>

    <!-- Sezione espandibile -->
    <VBox fx:id="expandedSection" spacing="8" maxWidth="Infinity" visible="false" managed="false"
          style="-fx-border-color: #e8e8e8; -fx-border-width: 1 0 0 0;">
        <padding>
            <Insets top="10" right="16" bottom="14" left="16"/>
        </padding>

        <!-- Riga 1: Titolo + Artista -->
        <HBox spacing="10">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="TITOLO" style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;"/>
                <TextField fx:id="editTitoloField" styleClass="form-field" promptText="Titolo"
                           style="-fx-font-size: 12px;" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="ARTISTA" style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;"/>
                <TextField fx:id="editArtistaField" styleClass="form-field" promptText="Artista"
                           style="-fx-font-size: 12px;" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <!-- Riga 2: Genere -->
        <VBox spacing="3">
            <Label text="GENERE" style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;"/>
            <ComboBox fx:id="editGenereCombo" editable="true" maxWidth="Infinity"
                      promptText="Genere" style="-fx-font-size: 12px;">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Ambient"/>
                        <String fx:value="Classica"/>
                        <String fx:value="Elettronica"/>
                        <String fx:value="Jazz"/>
                        <String fx:value="Pop"/>
                        <String fx:value="Rock"/>
                        <String fx:value="Strumentale"/>
                    </FXCollections>
                </items>
            </ComboBox>
        </VBox>

        <!-- Riga 3: Audio + Foto affiancati -->
        <HBox spacing="10">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="FILE AUDIO" style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;"/>
                <HBox spacing="6">
                    <TextField fx:id="editAudioPathField" editable="false"
                               promptText="Nessun file" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 11px;"/>
                    <Button text="…" fx:id="editBrowseAudio" style="-fx-font-size: 11px;"/>
                </HBox>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="COPERTINA" style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;"/>
                <HBox spacing="6">
                    <TextField fx:id="editFotoPathField" editable="false"
                               promptText="Nessuna immagine" HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 11px;"/>
                    <Button text="…" fx:id="editBrowsePhoto" style="-fx-font-size: 11px;"/>
                </HBox>
            </VBox>
        </HBox>

        <Label fx:id="editErrorLabel" style="-fx-font-size: 11px; -fx-text-fill: #c0392b;"
               visible="false" managed="false"/>

    </VBox>

</VBox>