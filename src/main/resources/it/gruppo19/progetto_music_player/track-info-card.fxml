<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox fillWidth="true" maxWidth="Infinity" styleClass="track-card" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12">

    <!-- Riga principale -->
    <HBox alignment="CENTER_LEFT" maxWidth="Infinity" minHeight="80" prefHeight="80" spacing="12" >

        <ImageView fx:id="cardImage" fitHeight="60" fitWidth="60" />

        <VBox alignment="CENTER_LEFT" spacing="4" minWidth="0" HBox.hgrow="ALWAYS">
            <Label fx:id="titleLabel" maxWidth="Infinity" styleClass="track-title" text="Titolo" />
            <Label fx:id="subtitleLabel" maxWidth="Infinity" styleClass="track-artist" text="Sottotitolo" />
            <Label fx:id="annoLabel" maxWidth="Infinity" styleClass="track-anno" text="Anno" />
        </VBox>

        <VBox alignment="BOTTOM_RIGHT" spacing="6" minWidth="-Infinity" HBox.hgrow="NEVER">
            <Label fx:id="durataLabel" styleClass="song-duration" text="--:--" />

            <HBox alignment="CENTER_RIGHT" spacing="8">
                <!-- Bottone Modifica (Matita) -->
                <Button fx:id="editButton" minWidth="36" minHeight="36" style="-fx-font-size: 18px;" text="✎" />

                <!-- Bottone Aggiungi a Playlist (+) -->
                <Button fx:id="addToPlaylistButton" minWidth="36" minHeight="36" style="-fx-font-size: 18px;" text="+" />

                <!-- Bottone Elimina (Trash) -->
                <Button fx:id="deleteButton" minWidth="36" minHeight="36" style="-fx-font-size: 18px;" text="🗑" />
            </HBox>
        </VBox>

    </HBox>

    <!-- Sezione espandibile -->
    <VBox fx:id="expandedSection" managed="false" maxWidth="Infinity" spacing="8" style="-fx-border-color: #e8e8e8; -fx-border-width: 1 0 0 0;" visible="false">
        <padding>
            <Insets bottom="14" left="16" right="16" top="10" />
        </padding>

        <!-- Riga 1: Titolo + Artista -->
        <HBox spacing="10">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;" text="TITOLO" />
                <TextField fx:id="editTitoloField" maxWidth="Infinity" promptText="Titolo" style="-fx-font-size: 12px;" styleClass="form-field" />
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;" text="ARTISTA" />
                <TextField fx:id="editArtistaField" maxWidth="Infinity" promptText="Artista" style="-fx-font-size: 12px;" styleClass="form-field" />
            </VBox>
        </HBox>

        <!-- Riga 2: Genere -->
        <VBox spacing="3">
            <Label style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;" text="GENERE" />
            <ComboBox fx:id="editGenereCombo" editable="true" maxWidth="Infinity" promptText="Genere" style="-fx-font-size: 12px;">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Ambient" />
                        <String fx:value="Classica" />
                        <String fx:value="Elettronica" />
                        <String fx:value="Jazz" />
                        <String fx:value="Pop" />
                        <String fx:value="Rock" />
                        <String fx:value="Strumentale" />
                    </FXCollections>
                </items>
            </ComboBox>
        </VBox>

        <!-- Riga 3: Audio + Foto affiancati -->
        <HBox spacing="10">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;" text="FILE AUDIO" />
                <HBox spacing="6">
                    <TextField fx:id="editAudioPathField" editable="false" promptText="Nessun file" style="-fx-font-size: 11px;" HBox.hgrow="ALWAYS" />
                    <Button fx:id="editBrowseAudio" style="-fx-font-size: 11px;" text="…" />
                </HBox>
            </VBox>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 9px; -fx-text-fill: #aaa; -fx-font-weight: bold;" text="COPERTINA" />
                <HBox spacing="6">
                    <TextField fx:id="editFotoPathField" editable="false" promptText="Nessuna immagine" style="-fx-font-size: 11px;" HBox.hgrow="ALWAYS" />
                    <Button fx:id="editBrowsePhoto" style="-fx-font-size: 11px;" text="…" />
                </HBox>
            </VBox>
        </HBox>

        <Label fx:id="editErrorLabel" managed="false" style="-fx-font-size: 11px; -fx-text-fill: #c0392b;" visible="false" />

    </VBox>

</VBox>
