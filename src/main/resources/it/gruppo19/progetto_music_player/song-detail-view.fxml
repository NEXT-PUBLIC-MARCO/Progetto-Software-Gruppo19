<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<!--
  Melodia - 03 Song Detail.
  Sidebar libreria + scheda dettaglio del brano selezionato.
  I campi con fx:id vengono valorizzati dal controller.
-->
<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.gruppo19.progetto_music_player.controller.SongDetailController"
      styleClass="app-root" prefWidth="1280.0" prefHeight="800.0"
      stylesheets="@styles.css">

    <!-- ============================ SIDEBAR ============================ -->
    <StackPane minWidth="380.0" prefWidth="380.0" maxWidth="380.0">
        <VBox styleClass="sidebar">
            <VBox styleClass="sidebar-header" spacing="24.0">
                <padding><Insets top="28.0" right="24.0" bottom="0.0" left="24.0"/></padding>
                <TextFlow styleClass="logo">
                    <Text styleClass="logo-melo" text="melo"/>
                    <Text styleClass="logo-dia" text="dia"/>
                </TextFlow>
                <HBox styleClass="segment">
                    <fx:define><ToggleGroup fx:id="tabGroup"/></fx:define>
                    <ToggleButton text="Brani" selected="true" toggleGroup="$tabGroup"
                                  styleClass="segment-btn" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <ToggleButton text="Playlist" toggleGroup="$tabGroup"
                                  styleClass="segment-btn" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <Label text="LIBRERIA" styleClass="section-label">
                <padding><Insets top="20.0" right="24.0" bottom="8.0" left="24.0"/></padding>
            </Label>

            <ScrollPane fitToWidth="true" styleClass="list-scroll" VBox.vgrow="ALWAYS">
                <VBox fx:id="songList" styleClass="song-list" spacing="2.0">
                    <padding><Insets top="16.0" right="12.0" bottom="16.0" left="12.0"/></padding>

                    <!-- riga selezionata (brano mostrato nel dettaglio) -->
                    <HBox styleClass="song-row, song-row-selected" alignment="CENTER_LEFT" spacing="12.0">
                        <Region styleClass="thumb"/>
                        <VBox styleClass="song-meta" HBox.hgrow="ALWAYS" spacing="1.0">
                            <Label text="Deriva Lenta" styleClass="song-title, song-title-active"/>
                            <Label text="Marco Vento" styleClass="song-artist"/>
                        </VBox>
                        <Region styleClass="now-dot"/>
                        <Label text="⋮" styleClass="song-duration"/>
                    </HBox>
                    <HBox styleClass="song-row" alignment="CENTER_LEFT" spacing="12.0">
                        <Region styleClass="thumb"/>
                        <VBox styleClass="song-meta" HBox.hgrow="ALWAYS" spacing="1.0">
                            <Label text="Cielo d'Inverno" styleClass="song-title"/>
                            <Label text="Elisa Fontana" styleClass="song-artist"/>
                        </VBox>
                        <Label text="3:47" styleClass="song-duration"/>
                    </HBox>
                    <HBox styleClass="song-row" alignment="CENTER_LEFT" spacing="12.0">
                        <Region styleClass="thumb"/>
                        <VBox styleClass="song-meta" HBox.hgrow="ALWAYS" spacing="1.0">
                            <Label text="Terre di Fuoco" styleClass="song-title"/>
                            <Label text="Nico Serrano" styleClass="song-artist"/>
                        </VBox>
                        <Label text="4:12" styleClass="song-duration"/>
                    </HBox>
                    <HBox styleClass="song-row" alignment="CENTER_LEFT" spacing="12.0">
                        <Region styleClass="thumb"/>
                        <VBox styleClass="song-meta" HBox.hgrow="ALWAYS" spacing="1.0">
                            <Label text="Silenzio Bianco" styleClass="song-title"/>
                            <Label text="Luca Marino" styleClass="song-artist"/>
                        </VBox>
                        <Label text="5:02" styleClass="song-duration"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>

        <Button fx:id="addButton" styleClass="fab" onAction="#onAdd" StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin><Insets bottom="24.0" right="25.0"/></StackPane.margin>
            <graphic><SVGPath styleClass="fab-icon" content="M10 4.167v11.666M4.167 10h11.666"/></graphic>
        </Button>
    </StackPane>

    <!-- ============================ DETTAGLIO BRANO ============================ -->
    <VBox styleClass="content-area-left" HBox.hgrow="ALWAYS" spacing="24.0">
        <padding><Insets top="48.0" right="48.0" bottom="48.0" left="48.0"/></padding>

        <Button styleClass="back-link" onAction="#onBack" text="‹  Torna ai brani"/>

        <VBox styleClass="detail-card" spacing="0.0" maxWidth="804.0">

            <!-- intestazione: copertina + metadati -->
            <HBox spacing="28.0">
                <Region fx:id="cover" styleClass="detail-art"/>
                <VBox HBox.hgrow="ALWAYS" spacing="8.0" alignment="CENTER_LEFT">
                    <Label text="BRANO" styleClass="badge-pill"/>
                    <Label fx:id="titolo" text="Deriva Lenta" styleClass="detail-title" wrapText="true"/>
                    <Label fx:id="artista" text="Marco Vento" styleClass="detail-artist"/>
                    <HBox spacing="20.0">
                        <Label fx:id="durata" text="3:44 durata" styleClass="detail-meta, detail-meta-strong"/>
                        <Label text="320 kbps" styleClass="detail-meta"/>
                        <Label fx:id="formato" text="FLAC" styleClass="detail-meta"/>
                    </HBox>
                </VBox>
            </HBox>

            <Region styleClass="dialog-divider">
                <VBox.margin><Insets top="28.0" bottom="24.0"/></VBox.margin>
            </Region>

            <Label text="DESCRIZIONE" styleClass="section-label"/>
            <Label fx:id="descrizione" styleClass="detail-desc" wrapText="true"
                   text="Un brano strumentale che evoca il lento scorrere di un fiume in autunno. Melodie morbide si intrecciano con sottili texture ambientali, creando un'atmosfera contemplativa e senza tempo. Registrato in studio con strumenti analogici.">
                <VBox.margin><Insets top="12.0" bottom="24.0"/></VBox.margin>
            </Label>

            <HBox spacing="12.0">
                <Button text="+  Aggiungi a playlist" styleClass="btn-primary" onAction="#onAddToPlaylist"/>
                <Button text="🗑  Elimina brano" styleClass="btn-danger-soft" onAction="#onDelete"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
